#!/bin/zsh
################################################################################
# Script Name:       remote-render
# Description:       Orchestrates remote 3D rendering by offloading Blender 
#                    workloads from a local thin client (laptop) to a high-
#                    performance homelab server via SSH/SCP.
# Author:            Stefan
# Version:           1.0
# Last Modified:     2026-04-24
# Dependencies:      zsh, ssh, scp, ping, rg, awk, sed, blender (remote)
# Hardware:          Requires SSH key-based authentication with host 'nbeje'
################################################################################

# ==============================================================================
# FUNCTIONALITY OVERVIEW
# ==============================================================================
# 1. Validates input existence and probes the remote render node's availability
#    using an ICMP echo request (ping).
# 2. Transfers the local .blend file to the remote /tmp/ directory via SCP.
# 3. Triggers a headless Blender render (`-b`) for a single frame (`-f 1`) via
#    SSH. Captures the output filename using regex and stream editing.
# 4. Automates the retrieval of the rendered image/video back to the local path.
# 5. Performs remote cleanup by removing temporary scene and output files.
# ==============================================================================

red='\033[1;31m'
green='\033[1;32m'
blue='\033[1;34m'
yellow='\033[0;33m'
nc='\033[0m'

# Check if a file argument was provided
if [[ $@ = "" ]];then
    echo "${yellow}No input files!${nc}"
else
    echo "${blue}Probing host..${nc}"
    # Verify connectivity to the DDNS endpoint before initiating transfer
    if [[ $(ping -c 1 -q nbeje.ddns.net | grep "1 received") != "" ]];then
        echo "Host ${green}ONLINE${nc}"
        
        echo "\n${blue}Uploading file..${nc}"
        scp $1 nbeje:/tmp/ 1>/dev/null
        echo "File upload ${green}DONE${nc}"
        
        echo "\n${blue}Starting render..${nc}"
        # Execute Blender in background mode. Logic:
        # - Extracts the saved filename from Blender's stdout using ripgrep (rg)
        # - Sanitizes the string (removes quotes) to identify the resulting file
        file=$(ssh nbeje blender-3.0 -b /tmp/$1 -o /tmp/ -f 1 2>/dev/null | rg "Saved" | awk -F '/' '{print $3}' | sed "s/'//g")
        ext=$(echo $file | awk -F '.' '{print $2}')
        
        if [[ $file != "" ]];then
            echo "Rendering ${green}DONE.${nc}"
            
            echo "\n${blue}Downloading output..${nc}"
            # Standardize filename on remote for easier scp retrieval
            ssh nbeje mv /tmp/$file /tmp/output.$ext
            scp nbeje:/tmp/output.$ext ./ 1>/dev/null
            
            # Post-processing cleanup to maintain server disk hygiene
            ssh nbeje sudo rm /tmp/output.$ext /tmp/$1
            echo "Download ${green}DONE.${nc}"
        else
            echo "File generation ${red}FAILED${nc}, exiting.."
        fi
    else
        echo "Host ${red}OFFLINE${nc}, exiting.."
    fi
fi

# ==============================================================================
# SECURITY CONSIDERATIONS
# ==============================================================================
# 1. SSH CONFIGURATION: Relies on the 'nbeje' alias in ~/.ssh/config. Ensure 
#    ForwardAgent is disabled and specific identity files are used (ED25519).
# 2. CLEAR-TEXT FILENAMES: Using $1 directly in scp/ssh commands is vulnerable 
#    to filenames containing spaces or shell metacharacters. Quote as "$1".
# 3. REMOTE SUDO USAGE: The script calls `sudo rm`. This requires NOPASSWD 
#    permissions in /etc/sudoers for the rm command on the server, which is a 
#    potential lateral movement vector if the local machine is compromised.
# 4. PATH TRAVERSAL: The scp command targets /tmp/. A malicious filename 
#    (e.g., "../etc/cron.d/exploit") could attempt to write outside /tmp/.
# 5. DATA IN FLIGHT: While SCP/SSH are encrypted, using a public DDNS endpoint 
#    exposes the render node to the internet. Ensure the remote SSH port is 
#    non-standard and hardened (Fail2Ban, Key-only auth).
# ==============================================================================